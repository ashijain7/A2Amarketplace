.venv/
__pycache__/
*.pyc
.pytest_cache/
.env
env.yaml
results/phase_1/
results/aggregates/
*.egg-info/
.DS_Store

# stray run console-logs at repo root (anchored so tracked results/**/rollout.log are untouched)
/output_*.log

# rescore undo-backups — kept on disk, deliberately out of git
*.pre_*_bak

# LaTeX build artifacts — paper source is tracked, these are regenerated by the IDE
A2A_COLM_2026/*.aux
A2A_COLM_2026/*.log
A2A_COLM_2026/*.blg
A2A_COLM_2026/*.fls
A2A_COLM_2026/*.out
A2A_COLM_2026/*.fdb_latexmk
A2A_COLM_2026/*.synctex.gz

# adapter + smoke per-run outputs (never committed)
results/adapter_runs/
results/smoke/
data/ng_run/

# vendored nemo_gym build artifacts (venvs already covered by .venv/ above)
nemo_gym_lib/build/
nemo_gym_lib/cache/*
!nemo_gym_lib/cache/.gitkeep

# Hydra per-run output dirs (runtime junk)
outputs/

# live-run scratch (regenerated every run; was tracked by mistake)
data/ng_run_live/
