.env.bak.*
.DS_Store

# transient run output
output.log
output.logs
outputs/
tasks/batches/
project_deal_approach_*/output.log
# output_phase*.log files — intentionally NOT ignored. They capture each
# rollout's ng_run trace (preflight, progress, snapshot, headline aggregator)
# and are useful for reproducibility / audit. Only the 14-char truncated
# API-key prefix appears in them, never the full key.
project_deal_approach_*/outputs/
project_deal_approach_*/tasks/batches/
