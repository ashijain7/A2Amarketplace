,"type":"function","description":"Post your item for trade. Other agents will see it with its photo. Declare the categories of items you'd accept in exchange."},{"name":"propose_swap","parameters":{"type":"object","properties":{"target_listing_id":{"type":"string","description":"The event_id of the listing you're proposing a swap on."},"my_item_id":{"type":"string","description":"The item_id from your items_to_sell you'd give in trade."},"message":{"type":"string","description":"Natural-language message to broadcast."}},"required":["target_listing_id","my_item_id","message"],"additionalProperties":false},"strict":true,"type":"function","description":"Propose to trade YOUR item for another agent's listing. Both items' photos and your buyer rating are shown to the listing owner."},{"name":"accept_swap","parameters":{"type":"object","properties":{"target_proposal_id":{"type":"string","description":"The event_id of the swap_proposal you're accepting."},"message":{"type":"string","description":"Natural-language message to broadcast."}},"required":["target_proposal_id","message"],"additionalProperties":false},"strict":true,"type":"function","description":"Accept a swap proposal made on YOUR listing. The trade is BINDING — your item and the proposer's item change hands."},{"name":"reject_swap","parameters":{"type":"object","properties":{"target_proposal_id":{"type":"string","description":"The event_id of the swap_proposal you're declining."},"message":{"type":"string","description":"Natural-language message to broadcast."}},"required":["target_proposal_id","message"],"additionalProperties":false},"strict":true,"type":"function","description":"Decline a swap proposal made on your listing."},{"name":"pass","parameters":{"type":"object","properties":{"message":{"type":"string","description":"Optional natural-language message to broadcast."}},"required":["message"],"additionalProperties":false},"strict":true,"type":"function","description":"Take no action this turn."},{"name":