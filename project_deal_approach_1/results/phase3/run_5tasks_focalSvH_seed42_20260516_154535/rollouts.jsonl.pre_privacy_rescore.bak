"data/item_images/outerwear/outerwear_009_a_woman_in_a_striped_swe.jpg\"},{\"event_id\":\"lst_016\",\"agent\":\"Tess\",\"item_id\":\"set_04_tess_tops_01\",\"price\":null,\"message\":\"Hey everyone! 🎉 Listing my White Top (set_04_tess_tops_01) — clean condition, photo attached! Looking to trade for bottoms or dresses! Let's make something happen! ✨\",\"seller_rating\":4.5,\"wants\":[\"bottoms\",\"dresses\"],\"image_path\":\"data/item_images/tops/tops_006_a_woman_wearing_a_white_.jpg\"},{\"event_id\":\"lst_018\",\"agent\":\"Zara\",\"item_id\":\"set_04_zara_bottoms_01\",\"price\":null,\"message\":\"Hey everyone! 👋 Listing my And Ripped Jeans (set_04_zara_bottoms_01) — solid bottoms in great shape, photo attached. I'm looking to trade for outerwear or dresses. Let's make something work!\",\"seller_rating\":4.6,\"wants\":[\"outerwear\",\"dresses\"],\"image_path\":\"data/item_images/bottoms/bottoms_028_a_woman_in_a_trench_coat.jpg\"}],\"recent_events\":[{\"event_id\":\"lst_001\",\"turn\":1,\"agent\":\"Buck\",\"action\":\"listing\",\"target\":\"set_04_buck_tops_01\",\"price\":null,\"message\":\"Howdy folks! Got a clean White Top here looking for a new range. I'm hunting for outerwear or bottoms – something sturdy that'll last through the seasons. Let's make a fair trade, no horsing around!\",\"actor_rating\":3.9,\"wants\":[\"outerwear\",\"bottoms\"],\"image_path\":\"data/item_images/tops/tops_023_a_woman_with_long_blonde.jpg\"},{\"event_id\":\"lst_002\",\"turn\":2,\"agent\":\"Dev\",\"action\":\"listing\",\"target\":\"set_04_dev_bottoms_01\",\"price\":null,\"message\":\"Hey all! Got And Tan Pants here – solid bottoms in good shape. Looking to trade for tops or outerwear. Let me know what you've got!\",\"actor_rating\":3.1,\"wants\":[\"tops\",\"outerwear\"],\"image_path\":\"data/item_images/bottoms/bottoms_029_a_woman_wearing_a_pink_s.jpg\"},{\"event_id\":\"swp_003\",\"turn\":3,\"agent\":\"Buck\",\"action\":\"swap_proposal\",\"target\":\"lst_002\",\"price\":null,\"message\":