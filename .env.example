# project_deal marketplace — runtime environment variables.
# Copy to .env for local use, OR pass with `docker run -e VAR=value`.
# The CACHED UI needs NONE of these; only LIVE runs need OPENROUTER_API_KEY.

# Required for LIVE runs (OpenRouter API key).
OPENROUTER_API_KEY=

# Injected by the RLEaaS platform at runtime (Step 6) — leave blank locally.
RLEAAS_CALLBACK_URL=
RLEAAS_TOKEN=
RLEAAS_ENV_NAME=project_deal_marketplace

# UI port. RLEaaS injects $PORT; local default is 8000.
# PORT=8000
